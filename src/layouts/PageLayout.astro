---
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import { getPageMetadata } from '../data/pageMetadata';
import { site } from '../data/site';
import '../styles/global.css';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const pageMetadata = getPageMetadata(path);

const {
  title,
  description,
  canonical,
  image = site.imageUrl,
  type = 'website',
  bodyClass = 'subpage-body',
  bodyId,
  headerHomeHref = '/',
  footerHomeHref = '/'
} = Astro.props;
const pageTitle = pageMetadata?.title ?? title ?? site.title;
const pageDescription = description ?? pageMetadata?.description ?? site.description;
const canonicalUrl = canonical ?? `${site.canonicalUrl}${path === '/' ? '' : path}`;
const imageUrl = image.startsWith('http') ? image : `${site.canonicalUrl}${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" sizes="192x192" href={site.icon} type="image/png" />
    <link rel="shortcut icon" href={site.icon} type="image/png" />
    <link rel="apple-touch-icon" href={site.icon} type="image/png" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="2500" />
    <meta property="og:image:height" content="1330" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content={type} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{pageTitle}</title>
  </head>
  <body id={bodyId} class={bodyClass}>
    <SiteHeader homeHref={headerHomeHref} />
    <slot />
    <SiteFooter homeHref={footerHomeHref} />
  </body>
</html>
