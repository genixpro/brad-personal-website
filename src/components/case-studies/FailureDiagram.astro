---
export interface Props {
  sourceLabel: string;
  resultLabel: string;
  source: string;
  result: string;
}

const { sourceLabel, resultLabel, source, result }: Props = Astro.props;
---

<div class="failure-diagram">
  <em>{sourceLabel}</em>
  <em>{resultLabel}</em>
  <span>{source}</span>
  <strong>{result}</strong>
</div>

<style>
  .failure-diagram {
    display: grid;
    grid-template-columns: 1fr 130px;
    gap: 12px 64px;
    align-items: center;
    margin: 36px 14px 0;
    color: var(--color-text-heading);
    text-align: center;
  }

  .failure-diagram em {
    font-size: 18px;
  }

  .failure-diagram span {
    padding: 18px 12px;
    border: 1px solid var(--color-border-neutral);
    font-size: 18px;
    text-align: left;
  }

  .failure-diagram strong {
    display: grid;
    place-items: center;
    min-height: 70px;
    background: var(--color-accent-success);
    border: 1px solid var(--color-accent-success-border);
    font-size: 20px;
    font-weight: 400;
  }

  @media (max-width: 640px) {
    .failure-diagram {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-inline: 0;
      text-align: left;
    }

    .failure-diagram strong {
      min-height: 56px;
    }
  }
</style>
