---
export interface Props {
  title: string;
  resumePdfUrl: string;
}

const { title, resumePdfUrl }: Props = Astro.props;
---

<section class="resume-title">
  <div class="container">
    <h1>{title}</h1>
  </div>
</section>
<section class="sub-section resume-viewer">
  <div class="container">
    <div class="pdf-embed-wrap">
      <iframe
        src={`${resumePdfUrl}#view=FitH`}
        title="Bradley Arsenault Resume PDF"
        class="pdf-embed"
        loading="lazy"
      />
    </div>
    <div class="resume-download">
      <a class="button button-secondary" href={resumePdfUrl} download="Bradley_Arsenault_Resume_2025.pdf">
        Download PDF
      </a>
      <p class="resume-fallback">
        If the embedded viewer does not load in your browser, use the Download PDF button above.
      </p>
    </div>
  </div>
</section>

<style>
  .resume-title {
    padding: 42px 0 18px;
    color: var(--white);
    background: #160f36;
    width: 100%;
  }

  .resume-title,
  .resume-title .container,
  .resume-title h1 {
    text-align: center;
  }

  .resume-title .container {
    display: grid;
    justify-items: center;
    width: calc(100% - 80px);
    max-width: var(--max);
    margin-inline: auto;
  }

  .resume-title .container,
  .resume-title h1 {
    width: 100%;
    margin-inline: auto;
  }

  .resume-title h1 {
    margin: 0;
    font-size: clamp(44px, 7vw, 78px);
  }

  @media (max-width: 768px) {
    .resume-title {
      padding: 28px 0 14px;
    }

    .resume-title h1 {
      font-size: 44px;
    }
  }

  .resume-viewer {
    padding-top: clamp(16px, 3vw, 24px);
  }

  .resume-viewer .container {
    display: grid;
    width: min(1120px, calc(100% - 80px));
    gap: 20px;
  }

  .pdf-embed-wrap {
    width: 100%;
    overflow: hidden;
    background: #fff;
    border: 1px solid #d5dde5;
    border-radius: 12px;
    box-shadow: 0 10px 35px rgba(16, 32, 60, 0.12);
  }

  .pdf-embed {
    display: block;
    width: 100%;
    height: min(180vh, 1960px);
    min-height: 1240px;
    border: none;
  }

  .resume-download {
    display: grid;
    gap: 12px;
    justify-items: start;
  }

  .resume-download .button {
    color: var(--white);
    background: #111319;
    border-color: #111319;
  }

  .resume-fallback {
    margin: 0;
    color: #49556a;
  }

  @media (max-width: 768px) {
    .resume-viewer .container {
      width: calc(100% - 32px);
    }

    .pdf-embed {
      min-height: 144vh;
    }
  }
</style>
