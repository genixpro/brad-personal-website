---
import { homeStats } from '../../data/home';
---

<section class="stats section-white">
  <div class="container">
    <h2>I've been building AI tech ever since</h2>
    <div class="stat-grid">
      {homeStats.map(({ value, label }) => (
        <div class="stat">
          <strong>{value}</strong>
          <span>{label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    position: relative;
    padding: 68px 0 74px;
    overflow: hidden;
    background:
      linear-gradient(90deg, var(--color-overlay-white-78) 0%, var(--color-overlay-white-68) 48%, var(--color-overlay-white-58) 100%),
      url('/assets/enlarge_genixpro_a_brite_white_web_page_banner_background_depicting_inf_a5077a00-d2ee-4766-b216-cbe4019667f3.png') center / cover no-repeat,
      var(--color-text-inverse);
  }

  .stats :global(.container) {
    position: relative;
    z-index: 1;
  }

  .stats h2 {
    max-width: 1120px;
    margin: 0 auto 36px;
    color: var(--color-text-heading);
    font-size: clamp(40px, 4.1vw, 58px);
    text-align: center;
  }

  .stat-grid {
    display: grid;
    width: min(860px, 100%);
    grid-template-columns: 1fr;
    gap: 22px;
    margin: 0 auto;
  }

  .stat {
    display: grid;
    grid-template-columns: 86px 1fr;
    gap: 34px;
    align-items: center;
    padding-top: 0;
    border-top: 0;
  }

  .stat strong {
    display: block;
    min-width: 0;
    margin-bottom: 0;
    color: var(--color-text-heading);
    font-size: clamp(42px, 5vw, 58px);
    line-height: 0.95;
    text-align: right;
  }

  .stat span {
    color: var(--color-text-heading);
    font-size: 24px;
    line-height: 1.25;
  }

  @media (max-width: 980px) {
    .stat-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .stats h2 {
      overflow-wrap: anywhere;
    }

    .stat-grid {
      grid-template-columns: 1fr;
    }

    .stat {
      grid-template-columns: 70px 1fr;
      gap: 18px;
    }

    .stat span {
      font-size: 21px;
    }
  }
</style>
