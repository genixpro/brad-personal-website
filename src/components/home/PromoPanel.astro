---
import { promos } from '../../data/home';
---

<section class="promos section-white">
  <article class="promo promo-owners">
    <div class="container promo-inner">
      <div class="promo-card">
        <h2>{promos.aiOwnersClub.title}</h2>
        <div class="owners-card-grid">
          <img src={promos.aiOwnersClub.image} alt={promos.aiOwnersClub.alt} />
          <div>
            <p>{promos.aiOwnersClub.copy}</p>
            <a class="button button-primary" href={promos.aiOwnersClub.href}>{promos.aiOwnersClub.cta}</a>
          </div>
        </div>
      </div>
    </div>
  </article>

  <article class="promo prospera">
    <div class="container promo-inner promo-reverse">
      <div class="promo-card prospera-card">
        <div>
          <h2>{promos.prospera.title}</h2>
          <p>{promos.prospera.copy}</p>
          <a class="button button-secondary dark-text" href={promos.prospera.href}>{promos.prospera.cta}</a>
        </div>
        <img src={promos.prospera.image} alt={promos.prospera.alt} loading="lazy" />
      </div>
    </div>
  </article>
</section>

<style>
  .promos {
    overflow: hidden;
  }

  .promo {
    position: relative;
    padding: 100px 0;
  }

  .promo-owners {
    color: var(--color-text-inverse);
    background:
      linear-gradient(var(--color-overlay-brand-92), var(--color-overlay-brand-94)),
      url('/assets/dark-city-banner.png') center / cover,
      var(--color-spotlight-cool);
  }

  .promo-owners::before {
    position: absolute;
    inset: 0;
    content: '';
    background:
      linear-gradient(var(--color-overlay-cyan-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-overlay-cyan-grid) 1px, transparent 1px);
    background-size: 42px 42px;
    opacity: 0.6;
  }

  .promo-inner {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
  }

  .promo-inner p {
    max-width: 720px;
    font-size: 20px;
  }

  .promo-card {
    width: min(850px, 100%);
    padding: clamp(30px, 5vw, 56px);
    color: var(--color-text-heading);
    background: var(--color-bg-surface);
  }

  .promo-card h2 {
    color: var(--color-text-heading);
    font-size: 56px;
    text-align: center;
  }

  .owners-card-grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    align-items: center;
  }

  .owners-card-grid img {
    width: 190px;
    margin-inline: auto;
  }

  .owners-card-grid p {
    font-size: 17px;
    font-weight: 800;
    line-height: 1.55;
  }

  .owners-card-grid .button {
    min-width: 150px;
    min-height: 42px;
    padding: 10px 22px;
    text-transform: none;
  }

  .prospera {
    background:
      linear-gradient(90deg, var(--color-spotlight-lime-strong), var(--color-spotlight-lime-soft)),
      url('/assets/network-wave-background.jpg') center / cover,
      var(--color-spotlight-lime);
  }

  .prospera-card {
    position: relative;
    display: block;
    padding: 56px 120px;
  }

  .prospera-card h2 {
    font-size: 46px;
    text-align: left;
  }

  .prospera-card p {
    max-width: 475px;
    font-size: 17px;
    font-weight: 800;
    line-height: 1.55;
  }

  .prospera-card img {
    position: absolute;
    top: 94px;
    right: 20px;
    display: block;
    width: 300px;
    max-width: 300px;
    mix-blend-mode: multiply;
  }

  .prospera-card .button {
    color: var(--color-text-heading);
    background: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    text-transform: none;
  }

  .dark-text {
    color: var(--color-text-primary);
  }

  @media (max-width: 980px) {
    .promo-inner,
    .owners-card-grid,
    .prospera-card {
      grid-template-columns: 1fr;
    }

    .prospera-card img {
      position: static;
      width: min(300px, 100%);
      margin-top: 28px;
    }
  }

  @media (max-width: 640px) {
    .promo {
      padding: 64px 0;
    }

    .promo-card {
      padding: 28px 24px;
    }

    .promo-card h2 {
      overflow-wrap: anywhere;
    }
  }
</style>
