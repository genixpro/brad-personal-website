---
import { consultingBullets } from '../../data/home';
---

<section class="consultation section-dark">
  <div class="container consultation-inner">
    <div>
      <p class="eyebrow">Let me help you build AI!</p>
      <h2>Let me help you build AI!</h2>
    </div>
    <ul>
      {consultingBullets.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
    <div class="consultation-card">
      <h3>Get a free AI product brainstorming and feasibility consultation!</h3>
      <label class="email-field">
        <span>Email Address</span>
        <input type="email" name="email" placeholder="Email Address" />
      </label>
      <a class="button button-maroon" href="https://calendly.com/bradleyarsenault">Get a Free Consultation</a>
    </div>
  </div>
</section>

<style>
  .consultation {
    position: relative;
    padding: 76px 0 94px;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(22, 15, 54, 0.96), rgba(22, 15, 54, 0.68)),
      url('/assets/cyber-laptop-background.jpg') center / cover,
      var(--black);
  }

  .consultation-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 430px 380px;
    justify-content: center;
    gap: 38px 72px;
    align-items: center;
    width: min(980px, calc(100% - 40px));
  }

  .consultation h2 {
    margin-bottom: 26px;
    font-size: clamp(42px, 5vw, 62px);
    text-align: center;
  }

  .consultation .eyebrow {
    display: none;
    margin-bottom: 16px;
    color: var(--cyan);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .consultation-inner > div:first-child {
    grid-column: 1 / -1;
  }

  .consultation-card {
    display: grid;
    gap: 20px;
    padding: 30px;
    color: var(--black);
    background: var(--white);
    grid-column: 2;
    grid-row: 2;
  }

  .consultation-card h3 {
    margin: 0;
    color: var(--black);
    font-size: 29px;
    line-height: 1.1;
  }

  .email-field {
    display: grid;
    gap: 6px;
    color: #4f4f58;
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
  }

  .email-field span {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .email-field input {
    width: 100%;
    min-height: 46px;
    padding: 10px 14px;
    border: 1px solid #a8a8b2;
    font: inherit;
  }

  .email-field input::placeholder {
    color: #4f4f58;
    opacity: 1;
  }

  .email-field::before {
    content: none;
  }

  .button-maroon {
    width: 100%;
    color: var(--white);
    background: var(--maroon);
    text-transform: none;
  }

  .consultation ul {
    display: grid;
    gap: 26px;
    margin: 0;
    padding-left: 26px;
    list-style: disc;
    list-style-position: outside;
    grid-column: 1;
    grid-row: 2;
  }

  .consultation li {
    position: relative;
    padding-left: 0;
    color: rgba(255, 255, 255, 0.86);
    font-size: 24px;
    line-height: 1.3;
  }

  .consultation li::before {
    content: none;
  }

  .consultation .button {
    justify-self: start;
  }

  @media (max-width: 980px) {
    .consultation-inner {
      grid-template-columns: 1fr;
    }

    .consultation-inner > div:first-child,
    .consultation-card,
    .consultation ul {
      grid-column: auto;
      grid-row: auto;
    }
  }

  @media (max-width: 640px) {
    .consultation-inner {
      width: min(var(--max), calc(100% - 28px));
    }

    .consultation h2 {
      overflow-wrap: anywhere;
    }

    .consultation-card {
      padding: 26px 20px;
    }

    .consultation li {
      font-size: 18px;
    }
  }
</style>
