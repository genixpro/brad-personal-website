---
import { originStory } from '../../data/home';
---

<section class="origin section-light">
  <div class="container origin-inner">
    <h2>{originStory.title}</h2>
    <div class="origin-grid">
      <div class="story-copy">
        {originStory.paragraphs.map((paragraph, index) => <p class:list={{ lead: index === originStory.paragraphs.length - 1 }}>{paragraph}</p>)}
      </div>
      <figure class="portrait">
        <img src={originStory.image} alt={originStory.imageAlt} />
        <figcaption>{originStory.caption}</figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .origin {
    padding: 30px 0 64px;
    background:
      linear-gradient(var(--color-overlay-paper-92), var(--color-overlay-paper-92)),
      url('/assets/robot-parts-background.jpg') center / cover,
      var(--color-bg-subtle);
  }

  .origin-inner {
    width: min(980px, calc(100% - 40px));
  }

  .origin-inner h2 {
    max-width: 866px;
    margin: 0 auto 36px;
    color: var(--color-text-heading);
    font-size: clamp(36px, 3.7vw, 48px);
    line-height: normal;
    text-align: center;
  }

  .origin-grid {
    display: grid;
    grid-template-columns: 500px 355px;
    gap: 125px;
    align-items: start;
  }

  .story-copy {
    color: var(--color-text-heading);
    font-family: Helvetica, Arial, sans-serif;
    font-size: 22px;
    font-weight: 300;
    line-height: normal;
    text-align: justify;
  }

  .story-copy p {
    margin-bottom: 0;
  }

  .story-copy p + p {
    margin-top: 0;
  }

  .story-copy .lead {
    max-width: 560px;
    margin-top: 36px;
    font-size: 21px;
    font-weight: 800;
    line-height: normal;
  }

  .portrait {
    margin: 0;
  }

  .portrait img {
    width: 355px;
    aspect-ratio: 1;
    object-fit: cover;
    border: 0;
    box-shadow: none;
  }

  .portrait figcaption {
    margin-top: 77px;
    color: var(--color-text-muted);
    font-size: 16px;
    font-style: italic;
    text-align: center;
  }

  @media (min-width: 981px) {
    .story-copy {
      padding-top: 8px;
    }

    .portrait figcaption {
      width: 420px;
      margin-left: -32px;
    }
  }

  @media (max-width: 980px) {
    .origin-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .origin {
      padding-block: 58px;
      padding-top: 34px;
    }

    .origin-inner {
      width: min(980px, calc(100% - 28px));
      margin-inline: auto;
    }

    .origin-inner h2 {
      overflow-wrap: anywhere;
    }
  }
</style>
