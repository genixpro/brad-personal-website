---
import { homeHero } from '../../data/home';
---

<section class="hero section-dark">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="container hero-content">
    <h1>{homeHero.title}</h1>
    <p class="hero-subtitle">{homeHero.subtitle}</p>
    <p class="hero-copy">
      {homeHero.copy}
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 429px;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(var(--color-overlay-brand-68), var(--color-overlay-brand-72)),
      url('/assets/network-wave-background.jpg') center / cover,
      linear-gradient(var(--color-overlay-cyan-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-overlay-cyan-grid) 1px, transparent 1px),
      radial-gradient(circle at 70% 18%, var(--color-overlay-cyan-glow), transparent 34%),
      var(--color-bg-brand-dark);
    background-size: auto, cover, 56px 56px, 56px 56px, auto, auto;
  }

  .hero::after {
    position: absolute;
    inset: 0;
    z-index: 1;
    content: '';
    background: linear-gradient(180deg, var(--color-overlay-brand-0), var(--color-overlay-brand-20) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    justify-items: center;
    align-content: center;
    min-height: 429px;
    padding: 136px 0 20px;
    text-align: center;
  }

  .hero h1 {
    line-height: 1.2;
  }

  .hero-subtitle {
    margin-bottom: 16px;
    font-size: clamp(42px, 4.2vw, 59px);
    font-weight: 800;
    line-height: 1.2;
  }

  .hero-copy {
    max-width: 860px;
    color: var(--color-overlay-white-86);
    font-size: clamp(22px, 1.8vw, 24px);
    font-weight: 800;
    line-height: 1.32;
  }

  @media (max-width: 640px) {
    .hero,
    .hero-content {
      min-height: 540px;
    }

    .hero-content {
      width: min(var(--max), calc(100% - 28px));
      margin-inline: auto;
      padding-top: 154px;
      padding-bottom: 54px;
    }

    .hero-subtitle {
      font-size: 34px;
    }

    .hero-copy {
      max-width: 850px;
    }
  }
</style>
