---
export type ContactLink = {
  label: string;
  href: string;
};

export interface Props {
  image: string;
  name: string;
  location?: string;
  phone?: string;
  email?: string;
  links?: ContactLink[];
}

const { image, name, location, phone, email, links = [] }: Props = Astro.props;
---

<div class="contact-profile">
  <img src={image} alt={name} />
  <h2>{name}</h2>
  {location && <p class="contact-line">{location}</p>}
  {phone && <p class="contact-line">{phone}</p>}
  {email && <p class="contact-line"><a href={`mailto:${email}`}>{email}</a></p>}
  {links.map(({ label, href }) => <p class="contact-line"><a href={href}>{label}</a></p>)}
</div>
