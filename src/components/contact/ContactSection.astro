---
import ContactForm from './ContactForm.astro';
import ContactProfile from './ContactProfile.astro';
import { contactPage } from '../../data/contact';
import { contactInfo } from '../../data/site';
---

<section class="sub-section contact-section">
  <div class="container contact-grid">
    <ContactProfile
      image={contactInfo.portrait}
      name={contactInfo.name}
      location={contactInfo.location}
      phone={contactInfo.phone}
      email={contactInfo.email}
      links={[{ label: contactInfo.calendly, href: contactInfo.calendly }]}
    />
    <div class="contact-main">
      <p>{contactPage.copy} <a href={contactPage.meetingHref}>{contactPage.meetingHref}</a></p>
      <ContactForm />
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding-top: 78px;
    background: var(--color-bg-surface);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
    gap: clamp(48px, 12vw, 285px);
    align-items: start;
  }

  .contact-main > p {
    max-width: 470px;
    margin-bottom: 60px;
    color: var(--color-contact-accent);
    font-size: 24px;
    line-height: 1.45;
    text-align: justify;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-grid > :global(*) {
      min-width: 0;
    }
  }

  @media (max-width: 640px) {
    .contact-section {
      padding-top: 54px;
    }

    .contact-main,
    .contact-main :global(.contact-form) {
      width: 100%;
      max-width: none;
    }

    .contact-main > p {
      width: 100%;
      margin-bottom: 42px;
      margin-left: 0;
      overflow-wrap: anywhere;
      text-align: left;
    }
  }
</style>
