---
export interface Props {
  src: string;
  fullSrc?: string;
  alt: string;
  title?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'auto' | 'sync';
  wrapperClass?: string;
  imageClass?: string;
}

const {
  src,
  fullSrc = src,
  alt,
  title = alt,
  loading = 'lazy',
  decoding,
  wrapperClass,
  imageClass
}: Props = Astro.props;
---

<button
  class:list={['image-lightbox-trigger', wrapperClass]}
  type="button"
  data-lightbox-src={fullSrc}
  data-lightbox-title={title}
>
  <img class={imageClass} src={src} alt={alt} loading={loading} decoding={decoding} />
</button>

<style>
  .image-lightbox-trigger {
    display: block;
    padding: 0;
    color: inherit;
    background: transparent;
    border: 0;
    cursor: zoom-in;
  }

  .image-lightbox-trigger:focus-visible {
    outline: 3px solid var(--cyan);
    outline-offset: 4px;
  }
</style>
