---
import type { CollectionEntry } from 'astro:content';
import { aboutPage } from '../../data/about';

export interface Props {
  services: CollectionEntry<'services'>[];
}

const { services }: Props = Astro.props;
---

<>
  <section class="about-panel">
    <div class="container about-panel-grid">
      <img src={aboutPage.image} alt="" />
      <div>
        <h1>{aboutPage.heading}</h1>
        <p class="about-kicker">{aboutPage.kicker}</p>
        <p>{aboutPage.body}</p>
        <a class="button button-blue" href={aboutPage.href}>{aboutPage.cta}</a>
      </div>
    </div>
  </section>
  <section class="about-service-band">
    <div class="container">
      <h2>{aboutPage.serviceBandTitle.split('\n')[0]}<br />{aboutPage.serviceBandTitle.split('\n')[1]}</h2>
      <p>{aboutPage.serviceBandBody}</p>
    </div>
  </section>
  <section class="about-services">
    <div class="container about-services-grid">
      {services.map(({ slug: serviceSlug, data }) => (
        <article>
          <h2>{serviceSlug === 'software-architecture-advising' ? 'Software Architecture Advisor' : data.title}</h2>
          <p>{data.intro}</p>
          <a href={`/${serviceSlug}`}>Learn More</a>
        </article>
      ))}
    </div>
  </section>
</>

<style>
  .about-panel {
    padding: 50px 0 44px;
    background:
      linear-gradient(var(--color-overlay-white-90), var(--color-overlay-white-86)),
      url('/assets/robot-parts-background.jpg') center / cover;
  }

  .about-panel-grid {
    display: grid;
    grid-template-columns: 360px minmax(0, 560px);
    gap: 66px;
    align-items: center;
  }

  .about-panel img {
    width: 360px;
    height: 486px;
    object-fit: cover;
  }

  .about-panel h1 {
    margin-bottom: 2px;
    color: var(--color-text-heading);
    font-size: 34px;
    font-weight: 400;
    line-height: 1.2;
  }

  .about-kicker {
    margin-bottom: 28px;
    color: var(--color-text-heading);
    font-size: 26px;
    font-style: italic;
    line-height: 1.2;
  }

  .about-panel p:not(.about-kicker) {
    color: var(--color-text-subtle);
    font-size: 18px;
    line-height: 1.45;
  }

  .about-panel .button {
    width: 236px;
    margin-top: 26px;
  }

  .about-service-band {
    padding: 70px 0 56px;
    min-height: 394px;
    color: var(--color-text-inverse);
    background:
      linear-gradient(var(--color-overlay-brand-88), var(--color-overlay-brand-90)),
      url('/assets/ai-control-room.jpg') center / cover;
    text-align: center;
  }

  .about-service-band h2 {
    margin-bottom: 30px;
    font-size: clamp(40px, 4vw, 48px);
  }

  .about-service-band p {
    max-width: 960px;
    margin: 0 auto;
    color: var(--color-text-inverse);
    font-size: 18px;
    font-weight: 800;
    line-height: 1.65;
  }

  .about-services {
    padding: 68px 0 82px;
    background: var(--color-bg-surface);
  }

  .about-services-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 44px 56px;
  }

  .about-services article {
    display: grid;
    align-content: start;
    min-height: 260px;
  }

  .about-services h2 {
    margin-bottom: 16px;
    color: var(--color-text-heading);
    font-size: 30px;
    line-height: 1.05;
  }

  .about-services p {
    color: var(--color-text-subtle);
    font-size: 17px;
    line-height: 1.45;
  }

  .about-services a {
    align-self: end;
    width: max-content;
    margin-top: 16px;
    color: var(--color-accent-link);
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .about-services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
