---
import { headerCta, navGroups, navLinks } from '../../data/navigation';

const {
  homeHref = '/'
}: {
  homeHref?: string;
} = Astro.props;

const primaryNavLinks = navLinks.map((link) => (link.label === 'Home' ? { ...link, href: homeHref } : link));

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
  if (href === '#' || href.startsWith('http')) return false;
  const normalizedHref = href.replace(/\/$/, '') || '/';
  return normalizedHref === currentPath;
};
---

<header class="site-header">
  <a class="brand" href={homeHref} aria-label="Bradley Arsenault home">
    <span>Bradley</span>
    <span>Arsenault</span>
  </a>
  <nav class="primary-nav" aria-label="Primary navigation">
    {primaryNavLinks.map(({ label, href }) => <a class:list={{ active: isActive(href) }} href={href}>{label}</a>)}
    {
      navGroups.map(({ label, links }) => (
        <details class:list={['nav-menu', { active: links.some(({ href }) => isActive(href)) }]}>
          <summary>{label}</summary>
          <div class="nav-menu-panel">
            {links.map(({ label, href }) => (
              <a class:list={{ active: isActive(href) }} href={href}>
                {label}
              </a>
            ))}
          </div>
        </details>
      ))
    }
  </nav>
  <a class="header-cta" href={headerCta.href}>{headerCta.label}</a>
</header>

<script>
  const navMenus = Array.from(document.querySelectorAll('.nav-menu'));

  const closeMenus = () => {
    for (const menu of navMenus) {
      if (menu.open) {
        menu.open = false;
      }
    }
  };

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!target.closest('.nav-menu')) {
      closeMenus();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenus();
    }
  });
</script>

<style>
  .primary-nav {
    align-items: center;
  }

  .nav-menu {
    position: relative;
  }

  .nav-menu summary,
  .nav-menu-panel a,
  .nav-menu-panel a:visited {
    color: var(--white);
    cursor: pointer;
    list-style: none;
  }

  .nav-menu summary::-webkit-details-marker {
    display: none;
  }

  .nav-menu summary:hover,
  .nav-menu summary:focus-visible,
  .nav-menu.active summary,
  .nav-menu-panel a:hover,
  .nav-menu-panel a:active,
  .nav-menu-panel a.active {
    color: var(--white);
  }

  .nav-menu-panel {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    z-index: 30;
    display: grid;
    min-width: 240px;
    gap: 10px;
    padding: 16px;
    background: rgba(4, 10, 22, 0.96);
    border: 1px solid rgba(21, 224, 251, 0.32);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.35);
  }

  .nav-menu-panel a {
    color: var(--white);
    font-size: 14px;
    line-height: 1.25;
  }

  @media (max-width: 980px) {
    .nav-menu {
      position: static;
    }

    .nav-menu-panel {
      position: fixed;
      top: 112px;
      left: 14px;
      right: 14px;
      min-width: 0;
      max-height: calc(100vh - 132px);
      overflow: auto;
    }
  }
</style>
