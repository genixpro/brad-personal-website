---
import { headerCta, navGroups, navLinks } from '../../data/navigation';

const {
  homeHref = '/'
}: {
  homeHref?: string;
} = Astro.props;

const primaryNavLinks = navLinks.map((link) => (link.label === 'Home' ? { ...link, href: homeHref } : link));

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
  if (href === '#' || href.startsWith('http')) return false;
  const normalizedHref = href.replace(/\/$/, '') || '/';
  return normalizedHref === currentPath;
};

const isExternal = (href: string) => href.startsWith('http');
---

<header class="site-header">
  <a class="brand" href={homeHref} aria-label="Bradley Arsenault home">
    <span>Bradley</span>
    <span>Arsenault</span>
  </a>
  <nav class="primary-nav" aria-label="Primary navigation">
    {primaryNavLinks.map(({ label, href }) => (
      <a
        class:list={{ active: isActive(href) }}
        href={href}
        aria-current={isActive(href) ? 'page' : undefined}
        target={isExternal(href) ? '_blank' : undefined}
        rel={isExternal(href) ? 'noopener noreferrer' : undefined}
      >
        {label}
      </a>
    ))}
    {
      navGroups.map(({ label, links }) => (
        <details class:list={['nav-menu', { active: links.some(({ href }) => isActive(href)) }]}>
          <summary>{label}</summary>
          <div class="nav-menu-panel">
            {links.map(({ label, href }) => (
              <a
                class:list={{ active: isActive(href) }}
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
                target={isExternal(href) ? '_blank' : undefined}
                rel={isExternal(href) ? 'noopener noreferrer' : undefined}
              >
                {label}
              </a>
            ))}
          </div>
        </details>
      ))
    }
  </nav>
  <a class="header-cta" href={headerCta.href}>{headerCta.label}</a>
</header>

<script>
  const navMenus = Array.from(document.querySelectorAll<HTMLDetailsElement>('.nav-menu'));

  const closeMenus = () => {
    for (const menu of navMenus) {
      if (menu.open) {
        menu.open = false;
      }
    }
  };

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (target instanceof Element && !target.closest('.nav-menu')) {
      closeMenus();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenus();
    }
  });
</script>

<style>
  .site-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 22px;
    align-items: center;
    width: 100%;
    margin-inline: auto;
    padding: 38px 0 18px 50px;
    color: var(--white);
    background: transparent;
    border-bottom: 0;
    backdrop-filter: none;
  }

  .primary-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: center;
    gap: 10px 32px;
    font-size: 16px;
    font-weight: 800;
    line-height: 1.2;
  }

  .primary-nav a {
    color: var(--white);
    cursor: pointer;
  }

  .brand:focus-visible,
  .primary-nav a:focus-visible,
  .nav-menu summary:focus-visible,
  .nav-menu-panel a:focus-visible,
  .header-cta:focus-visible {
    outline: 3px solid var(--cyan);
    outline-offset: 5px;
  }

  .primary-nav a:first-child,
  .primary-nav a:hover,
  .primary-nav a.active {
    color: var(--white);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 105px;
    height: 38px;
    min-height: 38px;
    padding: 0;
    color: var(--white);
    background: transparent;
    border: 4px solid var(--white);
    border-radius: 0;
    font-size: 16px;
    font-weight: 800;
    line-height: 1.1;
    white-space: nowrap;
    text-transform: none;
  }

  .header-cta:hover {
    transform: translateY(-1px);
  }

  :global(.subpage-body) .site-header {
    position: relative;
    align-items: center;
    width: 100%;
    min-height: 0;
    padding: 36px clamp(40px, 5vw, 72px) 18px;
    background: #160f36;
  }

  :global(.subpage-body) .primary-nav,
  :global(.subpage-body) .header-cta {
    margin-top: 0;
  }

  :global(.subpage-body) .primary-nav a:first-child:not(.active) {
    color: var(--white);
  }

  .nav-menu {
    position: relative;
  }

  .nav-menu summary,
  .nav-menu-panel a,
  .nav-menu-panel a:visited {
    color: var(--white);
    cursor: pointer;
    list-style: none;
  }

  .nav-menu summary::-webkit-details-marker {
    display: none;
  }

  .nav-menu summary:hover,
  .nav-menu summary:focus-visible,
  .nav-menu.active summary,
  .nav-menu-panel a:hover,
  .nav-menu-panel a:active,
  .nav-menu-panel a.active {
    color: var(--white);
  }

  .nav-menu-panel {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    z-index: 30;
    display: grid;
    min-width: 240px;
    gap: 10px;
    padding: 16px;
    background: rgba(4, 10, 22, 0.96);
    border: 1px solid rgba(21, 224, 251, 0.32);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.35);
  }

  .nav-menu-panel a {
    color: var(--white);
    font-size: 14px;
    line-height: 1.25;
  }

  @media (min-width: 981px) {
    .site-header {
      padding-right: 45px;
    }

    .primary-nav {
      gap: 10px 42px;
    }

    .header-cta {
      width: 120px;
    }
  }

  @media (max-width: 980px) {
    .site-header {
      grid-template-columns: 1fr auto;
    }

    .primary-nav {
      grid-column: 1 / -1;
      justify-content: flex-start;
      order: 3;
    }

    .nav-menu {
      position: static;
    }

    .nav-menu-panel {
      position: fixed;
      top: 112px;
      left: 14px;
      right: 14px;
      min-width: 0;
      max-height: calc(100vh - 132px);
      overflow: auto;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      width: 100%;
      padding: 14px 14px 18px;
      grid-template-columns: 1fr auto;
      gap: 12px 14px;
    }

    :global(.brand) {
      min-width: 0;
      font-size: 18px;
    }

    .header-cta {
      min-height: 40px;
      max-width: 112px;
      padding: 10px 13px;
      text-align: center;
    }

    .primary-nav {
      grid-column: 1 / -1;
      justify-content: flex-start;
      order: 3;
      flex-wrap: nowrap;
      gap: 18px;
      min-width: 0;
      width: 100%;
      max-width: 100%;
      max-height: none;
      overflow-x: auto;
      overflow-y: visible;
      padding-bottom: 8px;
      font-size: 12px;
      white-space: nowrap;
      scrollbar-width: none;
    }

    .primary-nav::-webkit-scrollbar {
      display: none;
    }

    :global(.subpage-body) .site-header {
      position: relative;
      width: 100%;
      min-height: 0;
      padding: 18px 20px 16px;
      gap: 14px;
    }
  }
</style>
