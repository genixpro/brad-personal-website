<dialog class="presentation-lightbox" data-presentation-lightbox aria-label="Presentation video">
  <button class="presentation-lightbox-close" type="button" data-presentation-lightbox-close aria-label="Close video">
    Close
  </button>
  <div class="presentation-lightbox-dialog">
    <div class="presentation-lightbox-frame" data-presentation-lightbox-frame></div>
  </div>
</dialog>

<script is:inline>
  const lightbox = document.querySelector('[data-presentation-lightbox]');
  const lightboxFrame = document.querySelector('[data-presentation-lightbox-frame]');
  const closeButton = document.querySelector('[data-presentation-lightbox-close]');
  const videoLinks = document.querySelectorAll('[data-presentation-video]');
  let activeTrigger = null;

  const closeLightbox = () => {
    if (!lightbox?.open) return;
    lightbox.close();
  };

  const resetLightbox = () => {
    if (!lightboxFrame) return;
    lightboxFrame.replaceChildren();
    document.body.classList.remove('presentation-lightbox-open');
    activeTrigger?.focus();
    activeTrigger = null;
  };

  const openLightbox = (videoSrc, title, trigger) => {
    if (!lightbox || !lightboxFrame) return;

    const isYouTube = videoSrc.includes('youtube.com') || videoSrc.includes('youtu.be');
    const media = isYouTube ? document.createElement('iframe') : document.createElement('video');

    if (isYouTube) {
      const separator = videoSrc.includes('?') ? '&' : '?';
      media.src = `${videoSrc}${separator}autoplay=1&rel=0`;
      media.title = title;
      media.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      media.allowFullscreen = true;
    } else {
      media.src = videoSrc;
      media.controls = true;
      media.autoplay = true;
      media.playsInline = true;
      media.setAttribute('aria-label', title);
    }

    lightboxFrame.replaceChildren(media);
    activeTrigger = trigger;
    document.body.classList.add('presentation-lightbox-open');
    lightbox.showModal();
    closeButton?.focus();
  };

  videoLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      const videoSrc = link.getAttribute('data-presentation-video');
      const title = link.getAttribute('data-presentation-title') || 'Presentation video';
      if (!videoSrc) return;

      event.preventDefault();
      openLightbox(videoSrc, title, link);
    });
  });

  closeButton?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) closeLightbox();
  });
  lightbox?.addEventListener('close', resetLightbox);
</script>

<style>
  .presentation-lightbox:not([open]) {
    display: none;
  }

  .presentation-lightbox {
    width: 100vw;
    max-width: none;
    height: 100vh;
    max-height: none;
    margin: 0;
    padding: clamp(20px, 5vw, 72px);
    color: var(--color-text-inverse);
    background: transparent;
    border: 0;
  }

  .presentation-lightbox[open] {
    display: grid;
    place-items: center;
  }

  .presentation-lightbox::backdrop {
    background: var(--color-overlay-deep-88);
  }

  :global(.presentation-lightbox-open) {
    overflow: hidden;
  }

  .presentation-lightbox-dialog {
    position: relative;
    width: min(1180px, 100%);
    background: var(--color-bg-media);
    box-shadow: 0 24px 80px var(--shadow-video-lightbox);
  }

  .presentation-lightbox-frame {
    aspect-ratio: 16 / 9;
    width: 100%;
  }

  .presentation-lightbox-frame :global(iframe),
  .presentation-lightbox-frame :global(video) {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    background: var(--color-bg-media);
  }

  .presentation-lightbox-close {
    position: fixed;
    top: clamp(18px, 3vw, 34px);
    right: clamp(18px, 3vw, 38px);
    z-index: 1;
    min-width: 82px;
    min-height: 38px;
    border: 2px solid var(--color-text-inverse);
    color: var(--color-text-inverse);
    background: transparent;
    font-family: inherit;
    font-size: 14px;
    font-weight: 800;
    cursor: pointer;
  }

  .presentation-lightbox-close:hover,
  .presentation-lightbox-close:focus-visible {
    color: var(--color-bg-brand-dark);
    background: var(--color-bg-surface);
  }
</style>
