---
import PresentationThumbnail from './PresentationThumbnail.astro';

export interface Presentation {
  title: string;
  image: string;
  href?: string;
  date?: string;
}

export interface Props extends Presentation {
  imageAlt?: string;
  imageLoading?: 'eager' | 'lazy';
}

const { title, image, href, date, imageAlt = '', imageLoading = 'lazy' }: Props = Astro.props;
const isExternalLink = href?.startsWith('http');
const resolvedImageAlt = imageAlt || title;
---

<article class="presentation-card">
  {
    href ? (
      <a
        class="presentation-card-link"
        href={href}
        data-presentation-video={href}
        data-presentation-title={title}
        target={isExternalLink ? '_blank' : undefined}
        rel={isExternalLink ? 'noopener noreferrer' : undefined}
      >
        <PresentationThumbnail image={image} alt={resolvedImageAlt} loading={imageLoading} />
        <h2>{title}</h2>
        {date && <time datetime={date}>{date}</time>}
      </a>
    ) : (
      <div class="presentation-card-content">
        <PresentationThumbnail image={image} alt={resolvedImageAlt} loading={imageLoading} />
        <h2>{title}</h2>
        {date && <time datetime={date}>{date}</time>}
      </div>
    )
  }
</article>

<style>
  .presentation-card {
    background: transparent;
    border: 0;
  }

  .presentation-card-link,
  .presentation-card-content {
    display: block;
    color: inherit;
  }

  .presentation-card-link:hover h2 {
    color: #1664d8;
  }

  .presentation-card h2 {
    display: -webkit-box;
    min-height: 50px;
    overflow: hidden;
    color: var(--black);
    font-size: clamp(22px, 1.9vw, 26px);
    line-height: 0.98;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .presentation-card time {
    display: block;
    margin-top: 10px;
    color: #5d6776;
    font-size: 14px;
    font-weight: 800;
    line-height: 1.2;
  }
</style>
