---
import { getEntry } from 'astro:content';
import LegalRoutePage from '../components/legal/LegalRoutePage.astro';

const legalPage = await getEntry('legal', 'terms-and-conditions');
if (!legalPage) throw new Error('Missing legal content: terms-and-conditions');
---

<LegalRoutePage legalPage={legalPage} slug="terms-and-conditions" />
