export function getStaticPaths() {
  const paths = [
    'portfolio',
    'case-studies',
    'mycreations',
    'presentations',
    'contact-me',
    'code-review-services',
    'code-refactoring-services',
    'software-architecture-advising',
    'ai-product-development',
    'ai-consulting',
    'machine-learning-architecture',
    'privacy-policy',
    'terms-and-conditions',
    'about',
    'book-an-intro-call',
    'book-ai-product-brainstorm',
    'webinar-signup',
    'resume',
    'case-studies/gensquared'
  ];
  return paths.map((path) => ({ params: { slug: path } }));
}

const slug = Astro.params.slug ?? '';
const service = servicePages[slug];
const legalPage = legal[slug];
const simple = simplePages[slug];
const isServicePage = Boolean(service);
const isSimpleHeroPage = simple && !['about', 'case-studies/gensquared'].includes(slug);
const pageClass = `subpage subpage-${slug.replace(/\//g, '-')}`;
const pageTitle =
  service?.title ??
  legalPage?.title ??
  simple?.title ??
  (slug === 'portfolio' || slug === 'case-studies'
    ? 'Portfolio'
    : slug === 'mycreations'
      ? 'My Creations'
      : slug === 'presentations'
        ? 'Presentations'
        : slug === 'contact-me'
          ? 'Contact me'
          : 'Portfolio');
const contactPortrait = '/assets/contact-bradley-portrait.png';
const gensquaredImage = '/assets/case-study-gensquared-bombardier.png';
---

<PageLayout title={`${pageTitle} | Bradley Arsenault`}>
  <main class={pageClass}>
    {((slug === 'portfolio' || slug === 'case-studies') || slug === 'presentations' || slug === 'contact-me' || legalPage || isSimpleHeroPage) && (
    <section class={`sub-hero sub-hero-${slug.replace(/\//g, '-')}`}>
      <div class="container">
        {(slug === 'portfolio' || slug === 'case-studies') && (
          <>
            <h1>Portfolio</h1>
            <p>Engineering Cutting Edge AI Solutions for 9+ years</p>
          </>
        )}
        {slug === 'presentations' && (
          <>
            <h1>Presentations</h1>
          </>
        )}
        {slug === 'contact-me' && <h1>Get in touch</h1>}
        {legalPage && <h1>{legalPage.title}</h1>}
        {isSimpleHeroPage && (
          <>
            <h1>{simple.title}</h1>
            <p>{simple.intro}</p>
            {simple.cta && <a class="button button-primary" href={simple.href}>{simple.cta}</a>}
          </>
        )}
      </div>
    </section>
    )}

    {service && (
      <section class="service-page-section">
        <div class="container service-page-grid">
          <div class="service-page-intro">
            <h1>{service.title}</h1>
            <p>{service.intro}</p>
          </div>
          <div class="service-page-list">
            {service.services.map((item) => (
              <article class="service-row">
                <span>{item.number}</span>
                <div>
                  <h2>{item.title}</h2>
                  <p>{item.body}</p>
                  {item.price && <strong>{item.price}</strong>}
                  <a class="button button-blue" href="/contact-me">Contact Me!</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    {(slug === 'portfolio' || slug === 'case-studies') && (
      <section class="sub-section">
        <div class="container portfolio-grid">
          {portfolio.map(({ title, industry, size, location, cost, year, time, image, ribbon, tags }, index) => (
            <article class="portfolio-card">
              <div class="portfolio-card-head">
                <h2>{title}</h2>
                <img class="portfolio-ribbon" src={ribbon} alt="" loading={index < 6 ? 'eager' : 'lazy'} />
              </div>
              <img class="portfolio-image" src={image} alt={title} loading={index < 6 ? 'eager' : 'lazy'} />
              <dl class="portfolio-details">
                <div><dt>Industry:</dt><dd>{industry}</dd></div>
                <div><dt>Company Size:</dt><dd>{size}</dd></div>
                <div><dt>Location:</dt><dd>{location}</dd></div>
              </dl>
              <div class="portfolio-tags" aria-label="Project tags">
                {tags.map((tag) => <span style={`--tag-bg: ${portfolioTagColors[tag] ?? '#117923'}`}>{tag}</span>)}
              </div>
              <dl class="portfolio-metrics">
                <div><dt>Cost:</dt><dd>{cost}</dd></div>
                <div><dt>Year:</dt><dd>{year}</dd></div>
                <div><dt>Project Time</dt><dd>{time}</dd></div>
              </dl>
            </article>
          ))}
        </div>
      </section>
    )}

    {slug === 'mycreations' && (
      <section class="creations-showcase">
        <div class="container creation-list">
          <h1>My Creations</h1>
          {creations.map(({ title, body, cta, href, secondaryCta, secondaryHref, image, alt }) => (
            <article class="creation-card">
              <div class="creation-copy">
                <h2>{title}</h2>
                <p>{body}</p>
                <div class="creation-actions">
                  <a class="button button-secondary" href={href}>{cta}</a>
                  {secondaryCta && secondaryHref && <a class="button button-secondary" href={secondaryHref}>{secondaryCta}</a>}
                </div>
              </div>
              <img src={image} alt={alt} loading="eager" decoding="async" />
            </article>
          ))}
        </div>
      </section>
    )}

    {slug === 'presentations' && (
      <section class="sub-section">
        <div class="container presentation-grid">
          {presentations.map(({ title, image }) => (
            <article class="presentation-card">
              <div class="video-placeholder">
                <img src={image} alt="" loading="lazy" />
                <span aria-hidden="true"></span>
              </div>
              <h2>{title}</h2>
            </article>
          ))}
        </div>
      </section>
    )}

    {slug === 'contact-me' && (
      <section class="sub-section contact-section">
        <div class="container contact-grid">
          <div class="contact-profile">
            <img src={contactPortrait} alt="Bradley Arsenault" />
            <h2>Bradley Arsenault</h2>
            <p class="contact-line">Toronto, Ontario, Canada</p>
            <p class="contact-line">+1-647-261-0462</p>
            <p class="contact-line"><a href="mailto:brad@bradleyarsenault.me">brad@bradleyarsenault.me</a></p>
            <p class="contact-line"><a href="https://calendly.com/bradleyarsenault">https://calendly.com/bradleyarsenault</a></p>
          </div>
          <div class="contact-main">
            <p>Feel free to reach out using any communication medium! For best results, book a meeting directly with me using my meeting link: <a href="https://calendly.com/bradleyarsenault">https://calendly.com/bradleyarsenault</a></p>
          <form class="contact-form" onsubmit="event.preventDefault()">
            <div class="form-row">
              <label>First Name<input name="firstName" required /></label>
              <label>Last Name<input name="lastName" required /></label>
            </div>
            <label>Email *<input type="email" name="email" required /></label>
            <label>Phone<input name="phone" placeholder="Phone" /></label>
            <label>Message<textarea name="message" required></textarea></label>
            <button class="button button-primary" type="submit">Send</button>
          </form>
          </div>
        </div>
      </section>
    )}

    {slug === 'about' && (
      <>
        <section class="about-panel">
          <div class="container about-panel-grid">
            <img src="/assets/profile-robot.jpg" alt="" />
            <div>
              <h1>Hi, I'm Brad,</h1>
              <p class="about-kicker">I build cool stuff with AI</p>
              <p>I'm an engineer, entrepreneur, freelancer, and all-around technology enthusiast. I offer wide range of services in software engineering and consulting. I specialize in custom AI product engineering, AI consulting, code refactoring, software architecture, and machine learning architecture. I love bringing new ideas to fruition, and pride myself on high quality work.</p>
              <a class="button button-blue" href="/contact-me">Contact Me</a>
            </div>
          </div>
        </section>
        <section class="about-service-band">
          <div class="container">
            <h2>Code Review, Refactoring &<br />Architecture Improvement</h2>
            <p>Is your development team getting slower and slower with every passing month? Did your engineers inherit a legacy code base that is considered a nightmare to maintain? Do you wish to proactively get ahead of technical debt and keep your code base easy and fast to grow? Take advantage of my code review, refactoring, and software architecture consulting services!</p>
          </div>
        </section>
        <section class="about-services">
          <div class="container about-services-grid">
            {Object.entries(servicePages).map(([href, item]) => (
              <article>
                <h2>{href === 'software-architecture-advising' ? 'Software Architecture Advisor' : item.title}</h2>
                <p>{item.intro}</p>
                <a href={`/${href}`}>Learn More</a>
              </article>
            ))}
          </div>
        </section>
      </>
    )}

    {slug === 'case-studies/gensquared' && (
      <section class="case-study-shell">
        <div class="case-study-wrap">
          <aside class="case-study-nav">
            <a href="/portfolio">&lt; Back</a>
            <div>Gensquared</div>
          </aside>
          <article class="case-study-card">
            <h1>Gensquared</h1>
            <div class="case-study-lede">
              <img src={gensquaredImage} alt="" />
              <p>GenSquared, a data and analytics company, was working with their client Bombardier to build a data and analytics pipeline for the firm. Bombardier came to them with a challenge - what kind of artificial intelligence could be applied to these airplane maintenance records in order to understand better what is going on? Lacking the deep artificial intelligence expertise, GenSquared in turn came to Bradley Arsenault to prototype deep learning models to these records.</p>
            </div>
            <p>To analyze this dataset, Bombardier had developed a standardized system of Failure Codes that each maintenance record could be classified as. This allowed Bombardier to track the trends of various maintenance issues over time. However, applying these standardized failure codes was a costly and error prone endeavour.</p>
            <p>Bombardier wanted to see if deep learning technology could be used to automated the classification of failure codes, and sure enough it could. Brad developed a deep-learning based classifier based on cutting edge AI research to automate the classification process, which was subsequently built into the data & analytics pipeline developed by GenSquared.</p>
            <div class="failure-diagram">
              <em>Original Airplane Maintenance Record</em>
              <em>Failure Code</em>
              <span>Jan 24, 2009 - repl. brake. pads burnt. overstress</span>
              <strong>FR-156</strong>
            </div>
          </article>
        </div>
      </section>
    )}

    {legalPage && (
      <section class="sub-section">
        <div class="container legal-copy">
          {legalPage.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>
    )}
  </main>
</PageLayout>
