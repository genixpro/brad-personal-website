---
import { getCollection } from 'astro:content';
import SubHero from '../components/common/SubHero.astro';
import PortfolioGrid from '../components/portfolio/PortfolioGrid.astro';
import { portfolioTagColors } from '../data/portfolioTags';
import PageLayout from '../layouts/PageLayout.astro';

const portfolioEntries = await getCollection('portfolio');
---

<PageLayout>
  <main class="subpage subpage-portfolio">
    <SubHero title="Portfolio" intro="Engineering Cutting Edge AI Solutions for 9+ years" variant="portfolio" />
    <PortfolioGrid entries={portfolioEntries} tagColors={portfolioTagColors} />
  </main>
</PageLayout>
