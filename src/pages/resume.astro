---
import SubHero from '../components/common/SubHero.astro';
import { simplePages } from '../data/simplePages';
import PageLayout from '../layouts/PageLayout.astro';

const page = simplePages.resume;
---

<PageLayout>
  <main class="subpage subpage-resume">
    <SubHero title={page.title} intro={page.intro} cta={{ label: page.cta, href: page.href }} variant="resume" />
  </main>
</PageLayout>
